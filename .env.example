# Reconciliation bot — credential reference. Copy to .env, fill in real values.
# .env is gitignored. NEVER commit real keys.
#
# IMPORTANT: the four API credentials below (Stripe / HubSpot / Slack / Sheets)
# are entered into n8n's OWN credential store via the n8n UI, not loaded from
# this file. This file is the documented checklist of everything an operator
# must obtain and where each value comes from. Postgres values here match the
# docker-compose defaults.

# --- Postgres (n8n backend + exception log) ---
# These mirror docker-compose.yml. Change them for a real deployment.
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Stripe (payments) ---
# Dashboard > Developers > API keys > Secret key. Use a TEST key for the demo.
STRIPE_SECRET_KEY=sk_test_xxx

# --- HubSpot (CRM / deals) ---
# Settings > Integrations > Private Apps. Scopes:
#   crm.objects.contacts.read, crm.objects.deals.read
HUBSPOT_TOKEN=pat-xxx

# --- Slack (alerting) ---
# api.slack.com > your app > Incoming Webhooks > Add New Webhook to Workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- Google Sheets (human-facing output) ---
# Google Cloud console > service account > JSON key. Enable the Sheets API and
# SHARE the target sheet with the service account's client_email as Editor.
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
GOOGLE_SHEET_ID=the-long-id-from-the-sheet-url
